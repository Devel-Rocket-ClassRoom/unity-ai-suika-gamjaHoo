{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$j = ($input | Out-String | ConvertFrom-Json); $f = $j.tool_input.file_path; if ($f -match '\\.cs$') { dotnet csharpier format $f 2>$null }",
            "shell": "powershell",
            "statusMessage": "CSharpier formatting..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(dotnet csharpier *)",
      "Bash(dotnet tool *)"
    ],
    "deny": [
      "Read(./Library/**)",
      "Read(!./Library/PackageCache/**)",
      "Read(./Temp/**)",
      "Read(./Logs/**)",
      "Read(./obj/**)",
      "Read(./**/*.csproj)",
      "Read(./**/*.sln)",
      "Write(./**/*.meta)",
      "Edit(./**/packages-lock.json)",
      "Edit(./**/*.unity)",
      "Write(./**/*.unity)",
      "Bash(rm -rf *)"
    ],
    "defaultMode": "default"
  }
}
